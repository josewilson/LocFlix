# ==========================================================================
# LOCFLIX — variáveis para o docker-compose (copie para .env e ajuste)
#   cp .env.example .env
# ==========================================================================

# --- Banco de dados (PostgreSQL EXTERNO já existente) ---------------------
# O banco "locflix" precisa existir no seu container Postgres (crie via DBeaver).
# host.docker.internal aponta para o host onde o Postgres está publicado (porta 5432).
DB_URL=jdbc:postgresql://host.docker.internal:5432/locflix
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- Segurança JWT (mínimo 256 bits / ~64 chars) --------------------------
JWT_SECRET=troque-este-segredo-por-um-bem-grande-troque-este-segredo-por-um-bem-grande
JWT_EXPIRATION=86400000

# --- CORS (origens do frontend) -------------------------------------------
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Usuário administrador inicial (bootstrap para acessar /admin) --------
# Defina e-mail e senha próprios. Se ficarem em branco, o admin não é criado.
ADMIN_ENABLED=true
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Locflix

# --- Integração externa de capas (opcional) -------------------------------
OMDB_API_KEY=
