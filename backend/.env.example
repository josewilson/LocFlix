# Variáveis de Ambiente para LOCFLIX
# Copie este arquivo para .env e preencha com seus valores

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/locadora
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-256-bits
JWT_EXPIRATION=86400000

# Bootstrap administrativo inicial (opcional; só para acessar /admin)
# Defina e-mail e senha próprios. Se ficarem em branco, o admin não é criado.
ADMIN_ENABLED=true
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Locflix

# Spring Profile (dev, prod)
SPRING_PROFILE=dev

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

